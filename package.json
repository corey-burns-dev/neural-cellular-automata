{
  "name": "neural-cellular-automata",
  "version": "1.0.0",
  "description": "Neural Cellular Automata (NCA) 'living' texture generator",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "format": "oxfmt",
    "deploy": "bun run build && bunx wrangler pages deploy dist",
    "deploy:production": "bun run build && bunx wrangler pages deploy dist --branch main",
    "prepare": "husky"
  },
  "devDependencies": {
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  }
}
